# --- OpenAI ---
# 從 https://platform.openai.com/api-keys 取得
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Whisper 語音辨識模型(預設 whisper-1)
WHISPER_MODEL=whisper-1
# 把口語拆成欄位的模型(便宜又夠用)
PARSE_MODEL=gpt-4o-mini

# --- Google Sheets ---
# 試算表 ID:網址 https://docs.google.com/spreadsheets/d/【這一段就是 ID】/edit
SPREADSHEET_ID=

# Service Account 金鑰 JSON 檔路徑(預設 ./service-account.json)
GOOGLE_SERVICE_ACCOUNT_KEY=./service-account.json

# 要寫入的工作表名稱(分頁名稱)
SHEET_NAME=記帳

# --- Server ---
PORT=3000
