# --- OpenAI ---
# 從 https://platform.openai.com/api-keys 取得
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Whisper 語音辨識模型(預設 whisper-1)
WHISPER_MODEL=whisper-1
# 把口語拆成欄位的模型(便宜又夠用)
PARSE_MODEL=gpt-4o-mini

# --- Google Sheets ---
# 試算表 ID:網址 https://docs.google.com/spreadsheets/d/【這一段就是 ID】/edit
SPREADSHEET_ID=

# Service Account 金鑰 JSON 檔路徑(預設 ./service-account.json)
GOOGLE_SERVICE_ACCOUNT_KEY=./service-account.json

# 要寫入的工作表名稱(分頁名稱)
SHEET_NAME=記帳

# --- 驗證 (magic link + JWT) ---
# JWT 簽章密鑰:請填一段夠長的隨機字串(可用 `openssl rand -hex 32` 產生)
JWT_SECRET=
# JWT 有效天數(預設 30)
JWT_TTL_DAYS=30
# 允許登入的 email 清單,逗號分隔
ALLOWED_EMAILS=you@example.com,family@example.com

# --- Brevo 寄信 ---
# Brevo 後台 → SMTP & API → API Keys 取得
BREVO_API_KEY=
# 寄件者 email(必須是 Brevo 已驗證的寄件者)
SENDER_EMAIL=
SENDER_NAME=語音記帳

# --- Server ---
# 對外網址(用來組 magic link),例如 https://iis.homo.tw
APP_URL=
PORT=3000
